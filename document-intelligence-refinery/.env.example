# =============================================================================
# Document Intelligence Refinery – environment variables
# Copy to .env and fill in your values. Do not commit .env.
# =============================================================================
#
# Stage 2: Structure Extraction Layer (Multi-Strategy)
# ---------------------------------------------------
# Strategy A (Fast Text): pdfplumber/pymupdf. No env required; thresholds in
#   rubric/extraction_rules.yaml (native_min_char_count, scanned_min_image_ratio).
# Strategy B (Layout): Docling/MinerU. No API keys; layout.use_docling in rules.
# Strategy C (Vision): VLM — uses Gemini by default.
# Escalation guard: A/B confidence gates in confidence.escalate_threshold_ab/bc;
#   low confidence triggers retry with next strategy (no silent bad data).
#
# =============================================================================

# -----------------------------------------------------------------------------
# Strategy C (Vision) + Query — Gemini (default provider)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# -----------------------------------------------------------------------------
# Week 5: Financial facts extraction determinism (recommended)
# -----------------------------------------------------------------------------
# When false, the `/v1/financial-facts/extract` endpoint will not use the vision/VLM
# strategy even if the PDF is scanned (it will cap at layout extraction).
REFINERY_FINANCIAL_FACTS_ALLOW_VISION=false

# -----------------------------------------------------------------------------
# Strategy C (Vision) / Query — OpenRouter (optional, paid VLM / budget-aware)
# Stage 2: "Gemini Flash / GPT-4o-mini via OpenRouter—budget-aware selection"
# Get key at https://openrouter.ai/keys | API: https://openrouter.ai/docs
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=

# -----------------------------------------------------------------------------
# Strategy C (Vision) / Query — OpenAI (optional, paid)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# LangSmith (tracing for query agent and escalation flow)
# -----------------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=document-intelligence-refinery

# -----------------------------------------------------------------------------
# Vector store (ChromaDB) — used after extraction for RAG
# -----------------------------------------------------------------------------
REFINERY_CHROMA_PATH=.refinery/chroma

# -----------------------------------------------------------------------------
# Frontend (Next.js). Only NEXT_PUBLIC_* are exposed to the browser.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_VISION_BUDGET_USD=20.0
