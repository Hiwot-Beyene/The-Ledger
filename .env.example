# OpenRouter — only the decision orchestrator uses the LLM (non-binding recommendation).
# Put keys HERE (repo root) — the staff API loads this file via python-dotenv. Not document-intelligence-refinery/.env.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_REFERER=http://localhost:5174
OPENROUTER_APP_TITLE=
OPENROUTER_ORCH_MAX_TOKENS=2048

# Set to 0 to skip orchestrator LLM entirely.
WORKFLOW_ORCH_LLM_ENABLED=1

# Force all agents to refuse LLM calls (orchestrator will fall back or skip).
# LEDGER_DETERMINISTIC_ONLY=1

# Week 3 refinery HTTP API (run document-intelligence-refinery on this port).
DOC_REFINERY_API_URL=http://127.0.0.1:8000

# Optional token-rate config for AgentSession cost fields.
LLM_INPUT_COST_USD_PER_1M_TOKENS=
LLM_OUTPUT_COST_USD_PER_1M_TOKENS=

# Orchestrator emits HumanReviewRequested only when confidence_score is strictly below this (aggregate REFER floor).
LEDGER_HITL_CONFIDENCE_THRESHOLD=0.6

# When confidence >= threshold and recommendation is APPROVE or DECLINE: HumanReviewCompleted + ApplicationApproved/Declined (set 0 for staff-only binding).
# LEDGER_AUTO_BIND_HIGH_CONFIDENCE=1
# LEDGER_AUTO_BINDING_REVIEWER_ID=SYSTEM-HIGH-CONFIDENCE
# If model says REFER but confidence meets floor (no HITL): bind as approve (default) or decline.
# LEDGER_AUTO_BIND_REFER_AS=approve

DATABASE_URL=
APPLICANT_REGISTRY_URL
DOCUMENTS_DIR=./documents
REGULATION_VERSION=2026-Q1
LOG_LEVEL=INFO

# STAFF_API_CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
